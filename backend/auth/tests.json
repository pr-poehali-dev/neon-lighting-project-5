{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/",
      "body": "{\"action\": \"register\", \"username\": \"plaintextuser\", \"password\": \"mypassword\"}",
      "expectedStatus": 200,
      "bodyMatcher": "none"
    },
    {
      "name": "Login with plain password",
      "method": "POST",
      "path": "/",
      "body": "{\"action\": \"login\", \"username\": \"plaintextuser\", \"password\": \"mypassword\"}",
      "expectedStatus": 200,
      "bodyMatcher": "none"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/",
      "body": "{\"action\": \"login\", \"username\": \"plaintextuser\", \"password\": \"wrongpass\"}",
      "expectedStatus": 401,
      "bodyMatcher": "none"
    }
  ]
}
